@model CompanySuggestViewModel
@{
    ViewData["Title"] = "Şirket Öner";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-building-add me-2"></i>Yeni Şirket Öner</h5>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-1"></i>
                    Önerdiğiniz şirket admin onayına gidecektir. Onay beklerken sadece siz bu şirketi başvurularınızda seçebilirsiniz.
                    Admin onayladığında tüm öğrenciler görebilir.
                </div>

                <form asp-action="SuggestCompany" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="Örn: ABC Yazılım A.Ş." />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Sector" class="form-label"></label>
                        <input asp-for="Sector" class="form-control" placeholder="Örn: Bilgi Teknolojileri" />
                        <span asp-validation-for="Sector" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Location" class="form-label"></label>
                        <input asp-for="Location" class="form-control" placeholder="Örn: İstanbul, Türkiye" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-send me-1"></i> Şirketi Öner
                        </button>
                        <a asp-action="Create" class="btn btn-outline-secondary">Geri Dön</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
}
