@model CareerTrack.Models.Entities.JobApplication
@{
    ViewData["Title"] = "Başvuru Detayı";
}

<div class="detail-card">
    <div class="detail-header">
        <div>
            <h3>@Model.Company?.Name</h3>
            <p class="text-muted mb-0">@Model.Position</p>
        </div>
        <span class="status-badge status-@Model.Status.ToString().ToLower() fs-6">
            @(Model.Status switch {
                ApplicationStatus.Pending => "Bekliyor",
                ApplicationStatus.InReview => "İncelemede",
                ApplicationStatus.Offered => "Teklif Alındı ✓",
                ApplicationStatus.Rejected => "Reddedildi",
                _ => Model.Status.ToString()
            })
        </span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="detail-item">
                <label>Başvuru Tarihi</label>
                <span>@Model.ApplicationDate.ToString("dd MMMM yyyy")</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="detail-item">
                <label>Staj Türü</label>
                <span>@(Model.InternshipType switch {
                    InternshipType.Voluntary => "Gönüllü Staj",
                    InternshipType.MandatoryShort => "Zorunlu Kısa Dönem",
                    InternshipType.LongTerm => "70 Günlük Uzun Dönem",
                    _ => Model.InternshipType.ToString()
                })</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="detail-item">
                <label>Şirket Konumu</label>
                <span>@Model.Company?.Location</span>
            </div>
        </div>
    </div>

    <!-- Mülakatlar -->
    <div class="section-header">
        <span><i class="bi bi-mic me-2"></i>Mülakat Aşamaları</span>
        <a asp-controller="Interview" asp-action="Create" asp-route-applicationId="@Model.Id"
           class="btn btn-sm btn-primary">+ Mülakat Ekle</a>
    </div>

    @if (!Model.Interviews.Any())
    {
        <p class="text-muted">Henüz mülakat eklenmedi.</p>
    }
    else
    {
        <div class="table-card">
            <table class="table align-middle mb-0">
                <thead>
                    <tr><th>Tarih</th><th>Aşama</th><th>Sonuç</th><th>Notlar</th></tr>
                </thead>
                <tbody>
                    @foreach (var iv in Model.Interviews.OrderBy(i => i.InterviewDate))
                    {
                        <tr>
                            <td>@iv.InterviewDate.ToString("dd.MM.yyyy")</td>
                            <td>@(iv.Stage switch {
                                InterviewStage.AptitudeTest => "Genel Yetenek Testi",
                                InterviewStage.LanguageTest => "Yabancı Dil Sınavı",
                                InterviewStage.HRInterview => "İK Mülakatı",
                                InterviewStage.TechnicalInterview => "Teknik Mülakat",
                                _ => iv.Stage.ToString()
                            })</td>
                            <td>
                                <span class="badge @(iv.ResultStatus == InterviewResult.Passed ? "bg-success" : iv.ResultStatus == InterviewResult.Failed ? "bg-danger" : "bg-warning text-dark")">
                                    @(iv.ResultStatus switch {
                                        InterviewResult.Passed => "Geçti ✓",
                                        InterviewResult.Failed => "Kaldı",
                                        _ => "Bekleniyor"
                                    })
                                </span>
                            </td>
                            <td>@(iv.Notes ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Teklif -->
    @if (Model.Status == ApplicationStatus.Offered && Model.Offer == null)
    {
        <div class="mt-4">
            <a asp-controller="Offer" asp-action="Create" asp-route-applicationId="@Model.Id"
               class="btn btn-success">
                <i class="bi bi-trophy me-1"></i> Teklif Detaylarını Gir
            </a>
        </div>
    }

    @if (Model.Offer != null)
    {
        <div class="offer-box mt-4">
            <h6><i class="bi bi-cash-coin me-2"></i>Teklif Detayları</h6>
            <div class="row g-2">
                <div class="col-md-3">
                    <label>Maaş</label>
                    <strong>@Model.Offer.Salary.ToString("N0") TL</strong>
                </div>
                <div class="col-md-5">
                    <label>Yan Haklar</label>
                    <strong>@(Model.Offer.Benefits ?? "-")</strong>
                </div>
                <div class="col-md-4">
                    <label>Son Dönüş</label>
                    <strong>@Model.Offer.DeadlineDate.ToString("dd.MM.yyyy")</strong>
                </div>
            </div>
        </div>
    }

    <div class="form-actions mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i> Düzenle
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">Geri Dön</a>
    </div>
</div>
