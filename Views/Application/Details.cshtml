@model CareerTrack.Models.Entities.JobApplication
@{
    ViewData["Title"] = "Başvuru Detayı";
}

<div class="detail-card">
    <div class="detail-header">
        <div>
            <h3>@Model.Company?.Name</h3>
            <p class="text-muted mb-0">@Model.Position</p>
        </div>
        <span class="status-badge status-@Model.Status.ToString().ToLower() fs-6">
            @(Model.Status switch {
                ApplicationStatus.SchoolPending => "Okul Onayı Bekliyor",
                ApplicationStatus.SchoolRevision => "Revize İstendi",
                ApplicationStatus.SchoolApproved => "Okul Onaylı",
                ApplicationStatus.PreScreening => "Ön Eleme",
                ApplicationStatus.AptitudeTest => "Test",
                ApplicationStatus.LanguageTest => "Dil Sınavı",
                ApplicationStatus.Interview => "Mülakat",
                ApplicationStatus.EmployerAccepted => "Kabul Edildi",
                ApplicationStatus.Rejected => "Reddedildi",
                ApplicationStatus.Completed => "Tamamlandı",
                _ => Model.Status.ToString()
            })
        </span>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="detail-item">
                <label>Başvuru Tarihi</label>
                <span>@Model.ApplicationDate.ToString("dd MMMM yyyy")</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="detail-item">
                <label>Staj Türü</label>
                <span>@(Model.InternshipType switch {
                    InternshipType.Voluntary => "Gönüllü Staj",
                    InternshipType.MandatoryShort => "Zorunlu Kısa Dönem",
                    InternshipType.LongTerm => "70 Günlük Uzun Dönem",
                    _ => Model.InternshipType.ToString()
                })</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="detail-item">
                <label>Şirket Konumu</label>
                <span>@Model.Company?.Location</span>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        @if (Model.InternshipStartDate.HasValue)
        {
            <div class="col-md-4">
                <div class="detail-item">
                    <label>Başlangıç Tarihi</label>
                    <span>@Model.InternshipStartDate.Value.ToString("dd MMMM yyyy")</span>
                </div>
            </div>
        }
        @if (Model.InternshipEndDate.HasValue)
        {
            <div class="col-md-4">
                <div class="detail-item">
                    <label>Bitiş Tarihi</label>
                    <span>@Model.InternshipEndDate.Value.ToString("dd MMMM yyyy")</span>
                </div>
            </div>
        }
        @if (Model.TotalInternshipDays.HasValue)
        {
            <div class="col-md-4">
                <div class="detail-item">
                    <label>Toplam Gün</label>
                    <span>@Model.TotalInternshipDays.Value Gün</span>
                </div>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.SchoolNote))
    {
        <div class="alert alert-info mt-3">
            <strong>Okul Notu:</strong> @Model.SchoolNote
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.EmployerNote))
    {
        <div class="alert alert-secondary mt-3">
            <strong>İşveren Notu:</strong> @Model.EmployerNote
        </div>
    }

    <div class="form-actions mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
            <i class="bi bi-pencil me-1"></i> Düzenle
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">Geri Dön</a>
    </div>
</div>
