@model IEnumerable<CareerTrack.Models.Entities.StudentTask>
@{
    ViewData["Title"] = "Görev Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-list-check me-2"></i>Atanan Görevler</h2>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#taskModal">
        <i class="bi bi-plus-lg me-1"></i>Yeni Görev Ata
    </button>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Öğrenci</th>
                            <th>Görev Başlığı</th>
                            <th>Son Tarih</th>
                            <th>Atanma Tarihi</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px; font-weight: bold;">
                                            @(string.IsNullOrWhiteSpace(task.JobApplication?.Student?.FullName) ? "Ö" : task.JobApplication.Student.FullName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <h6 class="mb-0">@task.JobApplication?.Student?.FullName</h6>
                                            <small class="text-muted">@task.JobApplication?.Student?.Department</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@task.Title</div>
                                    @if (!string.IsNullOrEmpty(task.Description))
                                    {
                                        <small class="text-muted d-block text-truncate" style="max-width: 200px;">@task.Description</small>
                                    }
                                </td>
                                <td>
                                    @if (task.DueDate.HasValue)
                                    {
                                        var isOverdue = DateTime.Now > task.DueDate.Value && !task.IsCompleted;
                                        <span class="@(isOverdue ? "text-danger fw-bold" : "")">
                                            @task.DueDate.Value.ToString("dd.MM.yyyy")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@task.CreatedAt.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (task.IsCompleted)
                                    {
                                        <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Tamamlandı</span>
                                        <div class="small text-muted mt-1">@task.CompletedAt?.ToString("dd.MM.yyyy HH:mm")</div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Devam Ediyor</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-list-task fs-1"></i>
                <p class="mt-3">Henüz öğrencilere atanmış bir görev bulunmuyor.</p>
                <button class="btn btn-outline-primary mt-2" data-bs-toggle="modal" data-bs-target="#taskModal">
                    <i class="bi bi-plus-lg me-1"></i>İlk Görevi Ata
                </button>
            </div>
        }
    </div>
</div>

<!-- Görev Ata Modalı -->
<div class="modal fade" id="taskModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-controller="Employer" asp-action="AssignTask" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header border-bottom-0 bg-light">
                    <h5 class="modal-title"><i class="bi bi-list-check me-2"></i>Yeni Görev Ata</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Stajyer Öğrenci *</label>
                        <select name="jobApplicationId" class="form-select" asp-items="@ViewBag.ActiveInterns" required>
                            <option value="">-- Aktif Stajyer Seçin --</option>
                        </select>
                        <small class="text-muted">Sadece okul onayını almış (stajı başlamış) öğrenciler listelenir.</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Görev Başlığı *</label>
                        <input type="text" name="title" class="form-control" required placeholder="Örn: Proje kurulumu, Veritabanı tasarımı..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Açıklama</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Görev detayları, yapılması gerekenler..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Son Teslim Tarihi</label>
                        <input type="date" name="dueDate" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer border-top-0 bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send-check me-1"></i>Görevi Ata
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
