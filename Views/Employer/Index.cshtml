@model EmployerDashboardViewModel
@{
    ViewData["Title"] = "İşveren Paneli";
}

<!-- İstatistik Kartları -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card stat-blue">
            <div class="stat-icon"><i class="bi bi-building"></i></div>
            <div class="stat-value fs-4 py-2 text-truncate" title="@Model.CompanyName">@Model.CompanyName</div>
            <div class="stat-label">Şirketiniz</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card stat-green">
            <div class="stat-icon"><i class="bi bi-megaphone"></i></div>
            <div class="stat-value count-anim">@Model.ActivePostings</div>
            <div class="stat-label">Aktif İlan (Toplam: @Model.TotalPostings)</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card stat-orange">
            <div class="stat-icon"><i class="bi bi-people"></i></div>
            <div class="stat-value count-anim">@Model.TotalApplications</div>
            <div class="stat-label">Toplam Başvuru</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card stat-red">
            <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
            <div class="stat-value count-anim">@Model.PendingApplications</div>
            <div class="stat-label">Bekleyen Başvuru</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Son İlanlar -->
    <div class="col-lg-6">
        <div class="card-section">
            <div class="section-header">
                <span><i class="bi bi-megaphone me-2 text-primary"></i>Son İlanlar</span>
                <a asp-action="Postings" class="see-all">Tümünü Gör</a>
            </div>
            <div class="p-0">
                @if (Model.RecentPostings.Any())
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Pozisyon</th>
                                    <th>Kontenjan</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var posting in Model.RecentPostings)
                                {
                                    <tr>
                                        <td class="fw-semibold">@posting.Title</td>
                                        <td>@posting.Quota kişi</td>
                                        <td>
                                            @if (posting.IsActive)
                                            {
                                                <span class="status-badge status-offered">Aktif</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge status-rejected">Pasif</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-megaphone fs-1 d-block mb-3 opacity-30"></i>
                        <p class="mb-3">Henüz ilan yayınlanmamış.</p>
                        <a asp-action="CreatePosting" class="btn btn-premium btn-sm">İlk İlanınızı Oluşturun</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Son Başvurular -->
    <div class="col-lg-6">
        <div class="card-section">
            <div class="section-header">
                <span><i class="bi bi-people me-2 text-success"></i>Son Başvurular</span>
                <a asp-action="Applications" class="see-all">Tümünü Gör</a>
            </div>
            <div class="p-0">
                @if (Model.RecentApplications.Any())
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>Öğrenci</th>
                                    <th>Pozisyon</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in Model.RecentApplications)
                                {
                                    <tr>
                                        <td class="fw-semibold">@app.Student?.FullName</td>
                                        <td>@app.Position</td>
                                        <td>
                                            @switch (app.Status)
                                            {
                                                case ApplicationStatus.SchoolApproved:
                                                    <span class="status-badge status-schoolapproved">Staj Devam Ediyor</span>
                                                    break;
                                                case ApplicationStatus.PreScreening:
                                                    <span class="status-badge status-inreview">Ön Eleme</span>
                                                    break;
                                                case ApplicationStatus.AptitudeTest:
                                                    <span class="status-badge status-inreview">G.Y. Testi</span>
                                                    break;
                                                case ApplicationStatus.LanguageTest:
                                                    <span class="status-badge status-inreview">Dil Sınavı</span>
                                                    break;
                                                case ApplicationStatus.Interview:
                                                    <span class="status-badge status-inreview">Mülakat</span>
                                                    break;
                                                case ApplicationStatus.EmployerAccepted:
                                                    <span class="status-badge status-offered">Kabul Edildi</span>
                                                    break;
                                                case ApplicationStatus.Rejected:
                                                    <span class="status-badge status-rejected">Reddedildi</span>
                                                    break;
                                                case ApplicationStatus.Completed:
                                                    <span class="status-badge status-completed">Staj Bitti</span>
                                                    break;
                                                default:
                                                    <span class="status-badge status-pending">@app.Status.ToString()</span>
                                                    break;
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-3 opacity-30"></i>
                        <p class="mb-0">Henüz başvuru yok.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
