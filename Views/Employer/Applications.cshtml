@model List<CareerTrack.Models.Entities.JobApplication>
@using CareerTrack.Models.Enums
@{
    ViewData["Title"] = "Yeni Başvurular";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-inbox-fill me-2 text-primary"></i>Yeni Gelen Başvurular <span class="badge bg-primary ms-2">Ön Eleme Kararı Verin</span></h4>
    <a asp-action="ProcessManagement" class="btn btn-outline-primary btn-sm rounded-pill">
        <i class="bi bi-diagram-3 me-1"></i> Süreç Yönetimi →
    </a>
</div>

<div class="alert mb-4 border-0 rounded-4 py-3 px-4" style="background: rgba(67,97,238,0.07); border-left: 4px solid var(--primary) !important;">
    <i class="bi bi-info-circle-fill me-2 text-primary"></i>
    <span class="text-secondary small">Bu sayfada yalnızca <strong class="text-white">yeni başvuranlar</strong> görünmektedir. Her aday için <strong class="text-info">Ön Elemeye Al</strong> veya <strong class="text-danger">Reddet</strong> kararı verebilirsiniz. Ön elemeyi geçen adaylar <strong>"Süreç Yönetimi"</strong> sekmesine taşınır.</span>
</div>

@if (Model.Any())
{
    <div class="table-card">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Öğrenci</th>
                    <th>Bölüm</th>
                    <th>Pozisyon</th>
                    <th>Başvuru Tarihi</th>
                    <th>Staj Türü</th>
                    <th class="text-end">Ön Eleme Kararı</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var app in Model)
                {
                    <tr>
                        <td class="fw-semibold">@app.Student?.FullName</td>
                        <td class="text-muted small">@app.Student?.Department</td>
                        <td>@app.Position</td>
                        <td>@app.ApplicationDate.ToString("dd.MM.yyyy")</td>
                        <td><span class="badge bg-secondary">@app.InternshipType</span></td>
                        <td class="text-end">
                            <div class="d-flex gap-2 justify-content-end">
                                <!-- Ön Elemeye Al -->
                                <form asp-action="UpdateApplicationStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@app.Id" />
                                    <input type="hidden" name="status" value="@((int)ApplicationStatus.PreScreening)" />
                                    <button type="submit" class="btn btn-sm btn-success rounded-pill px-3"
                                            onclick="return confirm('@app.Student?.FullName adlı adayı Ön Elemeye almak istediğinize emin misiniz?')">
                                        <i class="bi bi-check-circle me-1"></i> Ön Elemeye Al
                                    </button>
                                </form>
                                <!-- Reddet -->
                                <form asp-action="UpdateApplicationStatus" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@app.Id" />
                                    <input type="hidden" name="status" value="@((int)ApplicationStatus.Rejected)" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3"
                                            onclick="return confirm('@app.Student?.FullName adlı adayı reddetmek istediğinize emin misiniz?')">
                                        <i class="bi bi-x-circle me-1"></i> Reddet
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="table-card text-center py-5">
        <i class="bi bi-inbox fs-1 text-muted opacity-50 d-block mb-3"></i>
        <h5 class="text-muted">Bekleyen yeni başvuru yok</h5>
        <p class="text-muted small">Tüm başvurular değerlendirilmiş. Süreç devam eden adayları <a asp-action="ProcessManagement" class="text-primary">Süreç Yönetimi</a> sekmesinden takip edebilirsiniz.</p>
    </div>
}
