@model IEnumerable<CareerTrack.Models.Entities.DailyLog>
@{
    ViewData["Title"] = "Staj Günlükleri (Onay Bekleyenler)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-check me-2"></i>Staj Günlükleri</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Öğrenci</th>
                            <th>Gün</th>
                            <th>Tarih</th>
                            <th>İçerik Özeti</th>
                            <th>Durum</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@log.Student?.FullName</div>
                                    <small class="text-muted">@log.Student?.Department</small>
                                </td>
                                <td><span class="badge bg-secondary">@log.DayNumber. Gün</span></td>
                                <td>@log.LogDate.ToString("dd.MM.yyyy")</td>
                                <td class="text-truncate" style="max-width:250px;">
                                    @log.Content
                                </td>
                                <td>
                                    @switch (log.Status)
                                    {
                                        case CareerTrack.Models.Enums.DailyLogStatus.SentToEmployer:
                                            <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                                            break;
                                        case CareerTrack.Models.Enums.DailyLogStatus.EmployerApproved:
                                            <span class="badge bg-primary">Onayladınız</span>
                                            break;
                                        case CareerTrack.Models.Enums.DailyLogStatus.EmployerRejected:
                                            <span class="badge bg-danger">Reddettiniz</span>
                                            break;
                                        case CareerTrack.Models.Enums.DailyLogStatus.SchoolApproved:
                                            <span class="badge bg-success">Okul da Onayladı</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@log.Status.ToString()</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                            data-bs-target="#logModal" data-id="@log.Id"
                                            data-content="@log.Content" data-note="@log.EmployerNote"
                                            data-status="@log.Status.ToString()">
                                        <i class="bi bi-eye me-1"></i>İncele
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-journal-x fs-1"></i>
                <p class="mt-3">Şu anda onayınızı bekleyen staj günlüğü bulunmuyor.</p>
            </div>
        }
    </div>
</div>

<!-- Log İnceleme Modalı -->
<div class="modal fade" id="logModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <form asp-action="ApproveLog" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="modalLogId" />
                <div class="modal-header border-bottom-0 bg-light">
                    <h5 class="modal-title"><i class="bi bi-journal-text me-2"></i>Günlük İnceleme</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">ÖĞRENCİNİN GİRDİĞİ İÇERİK</label>
                        <div class="p-3 bg-light rounded" id="modalLogContent" style="min-height: 100px; white-space: pre-wrap;"></div>
                    </div>
                    
                    <div id="actionArea">
                        <div class="mb-3">
                            <label class="form-label fw-bold">İşveren Notu (Opsiyonel / Revize için zorunlu)</label>
                            <textarea name="employerNote" id="modalEmployerNote" class="form-control" rows="3" placeholder="Öğrenciye iletmek istediğiniz notlar..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 bg-light" id="modalFooter">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
                    <button type="submit" name="approve" value="false" class="btn btn-danger"><i class="bi bi-x-circle me-1"></i>Reddet / Revize İste</button>
                    <button type="submit" name="approve" value="true" class="btn btn-success"><i class="bi bi-check-circle me-1"></i>Onayla</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var logModal = document.getElementById('logModal');
            logModal.addEventListener('show.bs.modal', function (event) {
                var button = event.relatedTarget;
                var id = button.getAttribute('data-id');
                var content = button.getAttribute('data-content');
                var note = button.getAttribute('data-note');
                var status = button.getAttribute('data-status');

                logModal.querySelector('#modalLogId').value = id;
                logModal.querySelector('#modalLogContent').textContent = content;
                logModal.querySelector('#modalEmployerNote').value = note || '';

                var actionArea = logModal.querySelector('#actionArea');
                var footer = logModal.querySelector('#modalFooter');

                if (status === 'SentToEmployer') {
                    actionArea.style.display = 'block';
                    footer.style.display = 'flex';
                    logModal.querySelector('#modalEmployerNote').readOnly = false;
                } else {
                    // Sadece görüntüleme
                    logModal.querySelector('#modalEmployerNote').readOnly = true;
                    if (!note) {
                        actionArea.style.display = 'none';
                    }
                    footer.style.display = 'none';
                }
            });
        });
    </script>
}
