@model IEnumerable<CareerTrack.Models.Entities.DailyLog>
@{
    ViewData["Title"] = "Staj Günlükleri (Onay Bekleyenler)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal-check me-2"></i>Staj Günlükleri</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Öğrenci</th>
                            <th>Gün</th>
                            <th>Tarih</th>
                            <th>İçerik Özeti</th>
                            <th>Durum</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@log.Student?.FullName</div>
                                    <small class="text-muted">@log.Student?.Department</small>
                                </td>
                                <td><span class="badge bg-secondary">@log.DayNumber. Gün</span></td>
                                <td>@log.LogDate.ToString("dd.MM.yyyy")</td>
                                <td class="text-truncate" style="max-width:250px;">
                                    @log.Content
                                </td>
                                <td>
                                    @switch (log.Status)
                                    {
                                        case CareerTrack.Models.Enums.DailyLogStatus.SentToEmployer:
                                            <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                                            break;
                                        case CareerTrack.Models.Enums.DailyLogStatus.EmployerApproved:
                                            <span class="badge bg-primary">Onayladınız</span>
                                            break;
                                        case CareerTrack.Models.Enums.DailyLogStatus.EmployerRejected:
                                            <span class="badge bg-danger">Reddettiniz</span>
                                            break;
                                        case CareerTrack.Models.Enums.DailyLogStatus.SchoolApproved:
                                            <span class="badge bg-success">Okul da Onayladı</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@log.Status.ToString()</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" 
                                            onclick="openReviewDrawer(@log.Id, `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(log.Content))`, `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(log.EmployerNote ?? ""))`, '@log.Status.ToString()')">
                                        <i class="bi bi-eye me-1"></i>İncele
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-journal-x fs-1"></i>
                <p class="mt-3">Şu anda onayınızı bekleyen staj günlüğü bulunmuyor.</p>
            </div>
        }
    </div>
</div>

<!-- Log İnceleme Yan Paneli -->
<div id="logReviewDrawer" class="premium-drawer">
    <div class="drawer-overlay" onclick="closePremiumDrawer('logReviewDrawer')"></div>
    <div class="drawer-content">
        <div class="drawer-header">
            <span class="drawer-title"><i class="bi bi-journal-text me-2 text-primary"></i>Günlük İnceleme</span>
            <button type="button" class="btn-drawer-close" onclick="closePremiumDrawer('logReviewDrawer')">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="drawer-body">
            <form asp-action="ApproveLog" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="modalLogId" />
                
                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold">ÖĞRENCİNİN GİRDİĞİ İÇERİK</label>
                    <div class="p-3 rounded glass-panel" id="modalLogContent" style="min-height: 120px; white-space: pre-wrap; font-size: 0.95rem; line-height: 1.6; background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border);"></div>
                </div>
                
                <div id="actionArea" class="mb-4">
                    <label class="form-label fw-bold">İşveren Notu (Opsiyonel / Revize için zorunlu)</label>
                    <textarea name="employerNote" id="modalEmployerNote" class="form-control glass-input" rows="4" placeholder="Öğrenciye iletmek istediğiniz notlar..."></textarea>
                </div>
                
                <div class="d-flex gap-2" id="modalFooter">
                    <button type="button" class="btn btn-outline-secondary flex-fill" onclick="closePremiumDrawer('logReviewDrawer')">Kapat</button>
                    <button type="submit" name="approve" value="false" class="btn btn-danger flex-fill"><i class="bi bi-x-circle me-1"></i>Reddet / Revize</button>
                    <button type="submit" name="approve" value="true" class="btn btn-success flex-fill text-dark fw-bold"><i class="bi bi-check-circle me-1"></i>Onayla</button>
                </div>
                <div class="d-flex gap-2 d-none" id="viewOnlyFooter">
                    <button type="button" class="btn btn-outline-secondary w-100" onclick="closePremiumDrawer('logReviewDrawer')">Kapat</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openReviewDrawer(id, content, note, status) {
            document.getElementById('modalLogId').value = id;
            document.getElementById('modalLogContent').textContent = content;
            document.getElementById('modalEmployerNote').value = note || '';

            const actionArea = document.getElementById('actionArea');
            const footer = document.getElementById('modalFooter');
            const viewOnlyFooter = document.getElementById('viewOnlyFooter');
            const noteTextarea = document.getElementById('modalEmployerNote');

            if (status === 'SentToEmployer') {
                actionArea.classList.remove('d-none');
                footer.classList.remove('d-none');
                footer.classList.add('d-flex');
                viewOnlyFooter.classList.add('d-none');
                noteTextarea.readOnly = false;
            } else {
                noteTextarea.readOnly = true;
                if (!note || note.trim() === '') {
                    actionArea.classList.add('d-none');
                } else {
                    actionArea.classList.remove('d-none');
                }
                footer.classList.add('d-none');
                footer.classList.remove('d-flex');
                viewOnlyFooter.classList.remove('d-none');
                viewOnlyFooter.classList.add('d-flex');
            }

            window.openPremiumDrawer('logReviewDrawer');
        }
    </script>
}
