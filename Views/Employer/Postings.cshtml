@model List<JobPosting>
@{
    ViewData["Title"] = "İlanlarım";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">📋 Yayınlanan İlanlar</h4>
    <a asp-action="CreatePosting" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Yeni İlan Oluştur
    </a>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-hover shadow-sm rounded">
            <thead class="table-dark">
                <tr>
                    <th>Pozisyon</th>
                    <th>Staj Türü</th>
                    <th>Kontenjan</th>
                    <th>Başlangıç</th>
                    <th>Bitiş</th>
                    <th>Durum</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var posting in Model)
                {
                    <tr>
                        <td class="fw-semibold">@posting.Title</td>
                        <td>
                            @switch (posting.InternshipType)
                            {
                                case InternshipType.Voluntary:
                                    <span>Gönüllü</span>
                                    break;
                                case InternshipType.MandatoryShort:
                                    <span>Zorunlu Kısa</span>
                                    break;
                                case InternshipType.LongTerm:
                                    <span>Uzun Dönem</span>
                                    break;
                            }
                        </td>
                        <td>@posting.Quota kişi</td>
                        <td>@posting.StartDate.ToString("dd.MM.yyyy")</td>
                        <td>@posting.EndDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            @if (posting.IsActive)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pasif</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="EditPosting" asp-route-id="@posting.Id"
                               class="btn btn-sm btn-outline-primary me-1" title="Düzenle">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="TogglePosting" asp-route-id="@posting.Id"
                                  method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm @(posting.IsActive ? "btn-outline-warning" : "btn-outline-success") me-1"
                                        title="@(posting.IsActive ? "Pasif Yap" : "Aktif Yap")">
                                    <i class="bi @(posting.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                </button>
                            </form>
                            <form asp-action="DeletePosting" asp-route-id="@posting.Id"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('Bu ilanı silmek istediğinize emin misiniz?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-megaphone fs-1 text-muted"></i>
            <h5 class="mt-3 text-muted">Henüz ilan yayınlanmamış</h5>
            <a asp-action="CreatePosting" class="btn btn-primary mt-2">İlk İlanınızı Oluşturun</a>
        </div>
    </div>
}
