@using CareerTrack.Models.Constants
@using Microsoft.AspNetCore.Identity
@inject SignInManager<CareerTrack.Models.Entities.ApplicationUser> SignInManager
@inject UserManager<CareerTrack.Models.Entities.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CareerTrack</title>
    <link rel="icon" href="~/favicon.ico" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Google Fonts: Outfit and Plus Jakarta Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Anime.js Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.min.js"></script>
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CareerTrack.styles.css" asp-append-version="true" />

    @if (User.HasClaim("RequiresPasswordChange", "true") && ViewContext.RouteData.Values["Controller"]?.ToString() != "Profile")
    {
        <script>
            window.location.replace('/Profile/Settings');
        </script>
    }
</head>
<body>

@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var isAdmin = User.IsInRole(AppRoles.Admin);
    var isSchool = User.IsInRole(AppRoles.School);
    var isEmployer = User.IsInRole(AppRoles.Employer);
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var userInitial = string.IsNullOrWhiteSpace(currentUser?.FullName)
        ? "U"
        : currentUser.FullName.Trim().Substring(0, 1).ToUpper();
    var roleLabel = isAdmin ? "Admin" : isSchool ? "Okul" : isEmployer ? "İşveren" : "Öğrenci";
    int pendingTodos = ViewBag.PendingTodos ?? 0;
    int upcomingInterviews = ViewBag.UpcomingInterviews ?? 0;

    <div class="app-wrapper">
        <!-- ════ SIDEBAR ════ -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="brand-logo">
                    <i class="bi bi-briefcase-fill"></i>
                    <span>CareerTrack</span>
                </div>
            </div>

            <div class="sidebar-user">
                <div class="user-avatar">
                    @userInitial
                </div>
                <div class="user-info">
                    <div class="user-name">@currentUser?.FullName</div>
                    <div class="user-role">@roleLabel</div>
                </div>
            </div>

            <ul class="nav flex-column sidebar-nav">
                @if (isAdmin)
                {
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Admin" && currentAction == "Index" ? "active" : "")"
                           asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Admin" && currentAction == "Users" ? "active" : "")"
                           asp-controller="Admin" asp-action="Users">
                            <i class="bi bi-person-gear"></i> Kullanıcı Rolleri
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Admin" && currentAction == "DailyLogs" ? "active" : "")"
                           asp-controller="Admin" asp-action="DailyLogs">
                            <i class="bi bi-journal-check"></i> Staj Günlükleri
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Admin" && currentAction == "Applications" ? "active" : "")"
                           asp-controller="Admin" asp-action="Applications">
                            <i class="bi bi-people"></i> Tüm Başvurular
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Admin" && currentAction == "Companies" ? "active" : "")"
                           asp-controller="Admin" asp-action="Companies">
                            <i class="bi bi-building"></i> Şirket Yönetimi
                        </a>
                    </li>
                }
                else if (isSchool)
                {
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "School" && currentAction == "Index" ? "active" : "")"
                           asp-controller="School" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Okul Paneli
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "School" && currentAction == "DailyLogs" ? "active" : "")"
                           asp-controller="School" asp-action="DailyLogs">
                            <i class="bi bi-journal-check"></i> Günlük Onayları
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "School" && currentAction == "Applications" ? "active" : "")"
                           asp-controller="School" asp-action="Applications">
                            <i class="bi bi-briefcase"></i> Başvurular
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "School" && (currentAction == "StudentDetail" || currentAction == "Students") ? "active" : "")"
                           asp-controller="School" asp-action="Students">
                            <i class="bi bi-person-lines-fill"></i> Öğrenci Takibi
                        </a>
                    </li>
                }
                else if (isEmployer)
                {
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Employer" && currentAction == "Index" ? "active" : "")"
                           asp-controller="Employer" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Employer" && currentAction == "Postings" ? "active" : "")"
                           asp-controller="Employer" asp-action="Postings">
                            <i class="bi bi-megaphone-fill"></i> İlanlarım
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Employer" && currentAction == "CreatePosting" ? "active" : "")"
                           asp-controller="Employer" asp-action="CreatePosting">
                            <i class="bi bi-plus-circle-fill"></i> Yeni İlan
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Employer" && currentAction == "Applications" ? "active" : "")"
                           asp-controller="Employer" asp-action="Applications">
                            <i class="bi bi-people-fill"></i> Başvurular
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Employer" && currentAction == "ProcessManagement" ? "active" : "")"
                           asp-controller="Employer" asp-action="ProcessManagement">
                            <i class="bi bi-diagram-3-fill"></i> Süreç Yönetimi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Employer" && currentAction == "Tasks" ? "active" : "")"
                           asp-controller="Employer" asp-action="Tasks">
                            <i class="bi bi-list-check"></i> Görev Yönetimi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Employer" && currentAction == "DailyLogs" ? "active" : "")"
                           asp-controller="Employer" asp-action="DailyLogs">
                            <i class="bi bi-journal-text"></i> Öğrenci Günlükleri
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Dashboard" ? "active" : "")"
                           asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-house-fill"></i> Ana Sayfa
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Application" ? "active" : "")"
                           asp-controller="Application" asp-action="Index">
                            <i class="bi bi-send-fill"></i> Başvurularım
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "DailyLog" ? "active" : "")"
                           asp-controller="DailyLog" asp-action="Index">
                            <i class="bi bi-journal-text"></i> Staj Defteri
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "ToDo" ? "active" : "")"
                           asp-controller="ToDo" asp-action="Index">
                            <i class="bi bi-check2-circle"></i> Görev Listem
                            @if (pendingTodos > 0)
                            {
                                <span class="badge bg-danger ms-auto">@pendingTodos</span>
                            }
                        </a>
                    </li>
                }

                <li class="nav-item mt-2">
                    <hr class="border-secondary opacity-25 mx-3 my-2" />
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentController == "Profile" ? "active" : "")"
                       asp-controller="Profile" asp-action="Settings">
                        <i class="bi bi-person-gear"></i> Profil Ayarları
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-left"></i> <span>Çıkış Yap</span>
                    </button>
                </form>
            </div>
        </nav>

        <!-- ════ MAIN CONTENT ════ -->
        <div class="main-content">
            <!-- Header -->
            <header class="top-header">
                <button class="sidebar-toggle" type="button" data-sidebar-toggle>
                    <i class="bi bi-list"></i>
                </button>
                <div class="header-title">@ViewData["Title"]</div>
                <div class="header-actions">
                    @if (!isAdmin && !isSchool && !isEmployer && upcomingInterviews > 0)
                    {
                        <span class="header-badge">
                            <i class="bi bi-calendar-event"></i>
                            <span class="badge bg-warning text-dark">@upcomingInterviews mülakat</span>
                        </span>
                    }
                    <div class="header-user">
                        <i class="bi bi-person-circle fs-5"></i>
                        <span>@currentUser?.FullName</span>
                    </div>
                </div>
            </header>

            <!-- Premium Toast Container -->
            <div id="premium-toast-container" class="premium-toast-container"></div>

            <!-- Content Area -->
            <div class="content-area">
                @RenderBody()
            </div>
        </div>
    </div>
}
else
{
    <!-- Auth Layout (V2 Handles container internally) -->
    @RenderBody()
}

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        @if (TempData["Success"] != null)
        {
            <text>
            if (typeof window.showPremiumToast === 'function') {
                window.showPremiumToast("success", "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(TempData["Success"]?.ToString() ?? string.Empty))");
            }
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
            if (typeof window.showPremiumToast === 'function') {
                window.showPremiumToast("error", "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(TempData["Error"]?.ToString() ?? string.Empty))");
            }
            </text>
        }
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
