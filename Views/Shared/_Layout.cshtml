@using Microsoft.AspNetCore.Identity
@inject SignInManager<CareerTrack.Models.Entities.ApplicationUser> SignInManager
@inject UserManager<CareerTrack.Models.Entities.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CareerTrack</title>
    <link rel="icon" href="~/favicon.ico" />

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var isAdmin = User.IsInRole("Admin");
    int pendingTodos = ViewBag.PendingTodos ?? 0;
    int upcomingInterviews = ViewBag.UpcomingInterviews ?? 0;

    <div class="app-wrapper">
        <!-- ════ SIDEBAR ════ -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="brand-logo">
                    <i class="bi bi-briefcase-fill"></i>
                    <span>CareerTrack</span>
                </div>
            </div>

            <div class="sidebar-user">
                <div class="user-avatar">
                    @(currentUser?.FullName?.Substring(0, 1).ToUpper() ?? "U")
                </div>
                <div class="user-info">
                    <div class="user-name">@currentUser?.FullName</div>
                    <div class="user-role">@(isAdmin ? "Koordinatör" : "Öğrenci")</div>
                </div>
            </div>

            <ul class="nav flex-column sidebar-nav">
                @if (isAdmin)
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                           asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "DailyLogs" ? "active" : "")"
                           asp-controller="Admin" asp-action="DailyLogs">
                            <i class="bi bi-journal-check"></i> Staj Günlükleri
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Applications" ? "active" : "")"
                           asp-controller="Admin" asp-action="Applications">
                            <i class="bi bi-people"></i> Tüm Başvurular
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Companies" ? "active" : "")"
                           asp-controller="Admin" asp-action="Companies">
                            <i class="bi bi-building"></i> Şirket Yönetimi
                        </a>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                           asp-controller="Dashboard" asp-action="Index">
                            <i class="bi bi-house-fill"></i> Ana Sayfa
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Application" ? "active" : "")"
                           asp-controller="Application" asp-action="Index">
                            <i class="bi bi-send-fill"></i> Başvurularım
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "DailyLog" ? "active" : "")"
                           asp-controller="DailyLog" asp-action="Index">
                            <i class="bi bi-journal-text"></i> Staj Defteri
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ToDo" ? "active" : "")"
                           asp-controller="ToDo" asp-action="Index">
                            <i class="bi bi-check2-circle"></i> Görev Listem
                            @if (pendingTodos > 0)
                            {
                                <span class="badge bg-danger ms-auto">@pendingTodos</span>
                            }
                        </a>
                    </li>
                }
            </ul>

            <div class="sidebar-footer">
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-left"></i> Çıkış Yap
                    </button>
                </form>
            </div>
        </nav>

        <!-- ════ MAIN CONTENT ════ -->
        <div class="main-content">
            <!-- Header -->
            <header class="top-header">
                <button class="sidebar-toggle" onclick="document.getElementById('sidebar').classList.toggle('collapsed')">
                    <i class="bi bi-list"></i>
                </button>
                <div class="header-title">@ViewData["Title"]</div>
                <div class="header-actions">
                    @if (!isAdmin && upcomingInterviews > 0)
                    {
                        <span class="header-badge">
                            <i class="bi bi-calendar-event"></i>
                            <span class="badge bg-warning text-dark">@upcomingInterviews mülakat</span>
                        </span>
                    }
                    <div class="header-user">
                        <i class="bi bi-person-circle fs-5"></i>
                        <span>@currentUser?.FullName</span>
                    </div>
                </div>
            </header>

            <!-- Alert Messages -->
            <div class="content-area">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </div>
    </div>
}
else
{
    <!-- Auth Layout (Login / Register) -->
    <div class="auth-wrapper">
        <div class="auth-brand">
            <i class="bi bi-briefcase-fill"></i>
            <span>CareerTrack</span>
        </div>
        @RenderBody()
    </div>
}

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
