@model CareerTrack.Models.ViewModels.InterviewCreateViewModel
@{
    ViewData["Title"] = "Mülakatı Düzenle";
}

<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-pencil-fill me-2"></i>Mülakatı Düzenle
        @if (!string.IsNullOrEmpty(Model.CompanyName))
        {
            <small class="ms-2 opacity-75">— @Model.CompanyName / @Model.Position</small>
        }
    </div>
    <div class="form-card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="JobApplicationId" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="InterviewDate" class="form-label"></label>
                    <input asp-for="InterviewDate" class="form-control" type="date" />
                    <span asp-validation-for="InterviewDate" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Stage" class="form-label"></label>
                    <select asp-for="Stage" class="form-select"
                            asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.InterviewStage>()">
                    </select>
                </div>

                <div class="col-md-4">
                    <label asp-for="ResultStatus" class="form-label"></label>
                    <select asp-for="ResultStatus" class="form-select"
                            asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.InterviewResult>()">
                    </select>
                </div>

                <div class="col-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="4"
                              placeholder="Mülakat hakkında notlarınız..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-actions mt-4">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save me-1"></i> Güncelle
                </button>
                <a asp-action="Index" asp-route-applicationId="@Model.JobApplicationId"
                   class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
}
