@model CareerTrack.Models.ViewModels.InterviewCreateViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Mülakat Ekle" : "Mülakatı Düzenle";
}

<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-mic-fill me-2"></i>@ViewData["Title"]
        @if (!string.IsNullOrEmpty(Model.CompanyName))
        {
            <small class="text-muted ms-2">— @Model.CompanyName / @Model.Position</small>
        }
    </div>
    <div class="form-card-body">
        <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="JobApplicationId" />
            @if (Model.Id != 0) { <input type="hidden" asp-for="Id" /> }

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="InterviewDate" class="form-label"></label>
                    <input asp-for="InterviewDate" class="form-control" type="date" />
                    <span asp-validation-for="InterviewDate" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Stage" class="form-label"></label>
                    <select asp-for="Stage" class="form-select"
                            asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.InterviewStage>()">
                    </select>
                </div>

                <div class="col-md-4">
                    <label asp-for="ResultStatus" class="form-label"></label>
                    <select asp-for="ResultStatus" class="form-select"
                            asp-items="Html.GetEnumSelectList<CareerTrack.Models.Enums.InterviewResult>()">
                    </select>
                </div>

                <div class="col-12">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="3"
                              placeholder="Mülakat hakkında notlarınız..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-actions mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Kaydet</button>
                <a asp-action="Index" asp-route-applicationId="@Model.JobApplicationId" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScripts" /> }
