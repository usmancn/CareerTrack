@model CareerTrack.Models.Entities.Offer
@{
    ViewData["Title"] = "Teklif Detayları";
}

<div class="form-card">
    <div class="form-card-header" style="background: linear-gradient(135deg, #065f46, #10b981);">
        <i class="bi bi-trophy-fill me-2"></i>Teklif Alındı!
        <small class="ms-2 opacity-75">— @Model.JobApplication?.Company?.Name / @Model.JobApplication?.Position</small>
    </div>
    <div class="form-card-body">
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="detail-item">
                    <label>Aylık Maaş</label>
                    <span class="fs-4 fw-bold text-success">@Model.Salary.ToString("N0") TL</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="detail-item">
                    <label>Yan Haklar</label>
                    <span>@(Model.Benefits ?? "Belirtilmedi")</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="detail-item">
                    <label>Son Dönüş Tarihi</label>
                    <span class="@(Model.DeadlineDate < DateTime.Today ? "text-danger fw-bold" : "")">
                        @Model.DeadlineDate.ToString("dd MMMM yyyy")
                        @if (Model.DeadlineDate < DateTime.Today)
                        {
                            <span class="badge bg-danger ms-1">Süresi Geçti!</span>
                        }
                        else
                        {
                            var remaining = (Model.DeadlineDate - DateTime.Today).Days;
                            <span class="badge bg-warning text-dark ms-1">@remaining gün kaldı</span>
                        }
                    </span>
                </div>
            </div>
        </div>

        @if (Model.IsAccepted)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill me-2"></i>
                <strong>Teklif Kabul Edildi!</strong> Staj defterinizi yazmaya başlayabilirsiniz.
            </div>
            <a asp-controller="DailyLog" asp-action="Index" class="btn btn-success">
                <i class="bi bi-journal-text me-1"></i> Staj Defterime Git
            </a>
        }
        else
        {
            <form asp-action="Accept" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success"
                        onclick="return confirm('Teklifi kabul etmek istediğinizden emin misiniz?')">
                    <i class="bi bi-check-circle me-1"></i> Teklifi Kabul Et
                </button>
            </form>
        }

        <a asp-controller="Application" asp-action="Index" class="btn btn-outline-secondary ms-2">
            <i class="bi bi-arrow-left me-1"></i> Başvurularıma Dön
        </a>
    </div>
</div>
