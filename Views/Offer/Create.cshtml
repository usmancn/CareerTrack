@model CareerTrack.Models.Entities.Offer
@{
    ViewData["Title"] = "Teklif Ekle";
    var app = ViewBag.Application as CareerTrack.Models.Entities.JobApplication;
}

<div class="form-card">
    <div class="form-card-header" style="background: linear-gradient(135deg, #065f46, #10b981);">
        <i class="bi bi-trophy me-2"></i>Teklif Detaylarını Gir
        @if (app != null)
        {
            <small class="ms-2 opacity-75">— @app.Company?.Name / @app.Position</small>
        }
    </div>
    <div class="form-card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="JobApplicationId" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Salary" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="Salary" class="form-control" type="number" min="0" step="100"
                               placeholder="15000" />
                        <span class="input-group-text">TL</span>
                    </div>
                    <span asp-validation-for="Salary" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DeadlineDate" class="form-label"></label>
                    <input asp-for="DeadlineDate" class="form-control" type="date"
                           min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="DeadlineDate" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Benefits" class="form-label"></label>
                    <input asp-for="Benefits" class="form-control"
                           placeholder="Örn: Yol + Yemek, Özel Sağlık Sigortası..." />
                    <span asp-validation-for="Benefits" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-actions mt-4">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-save me-1"></i> Teklifi Kaydet
                </button>
                <a asp-controller="Application" asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
}
