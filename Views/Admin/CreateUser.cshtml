@model CareerTrack.Models.ViewModels.AdminCreateUserViewModel
@using CareerTrack.Models.Constants
@{
    ViewData["Title"] = "Yeni Kullanıcı Ekle";
}

<div class="form-card mx-auto" style="max-width: 600px;">
    <div class="form-card-header bg-primary text-white">
        <i class="bi bi-person-plus-fill me-2"></i>Yeni Kullanıcı Ekle
    </div>
    <div class="form-card-body p-4">
        <form asp-action="CreateUser" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-bold"></label>
                <input asp-for="FullName" class="form-control" placeholder="Ad Soyad giriniz" />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold"></label>
                <input asp-for="Email" class="form-control" placeholder="ornek@okul.edu.tr" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-bold"></label>
                <input asp-for="Password" class="form-control" placeholder="Geçici şifre belirleyiniz" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Role" class="form-label fw-bold"></label>
                <select asp-for="Role" class="form-select">
                    <option value="@AppRoles.Student">Öğrenci</option>
                    <option value="@AppRoles.Employer">İşveren</option>
                    <option value="@AppRoles.School">Okul Personeli / Koordinatör</option>
                    <option value="@AppRoles.Admin">Admin</option>
                </select>
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Department" class="form-label fw-bold"></label>
                <input asp-for="Department" class="form-control" placeholder="Bölüm, Fakülte veya Kurum adı (Opsiyonel)" />
                <span asp-validation-for="Department" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-4">
                <a asp-action="Users" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Listeye Dön
                </a>
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-check-circle me-1"></i>Kullanıcıyı Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
}
