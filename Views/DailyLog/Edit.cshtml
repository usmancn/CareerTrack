@model CareerTrack.Models.ViewModels.DailyLogCreateViewModel
@{
    ViewData["Title"] = "Günlüğü Düzenle";
}

<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-pencil-fill me-2"></i>Günlüğü Düzenle
    </div>
    <div class="form-card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="DayNumber" class="form-label"></label>
                    <input asp-for="DayNumber" class="form-control" type="number" min="1" max="365" />
                    <span asp-validation-for="DayNumber" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="LogDate" class="form-label"></label>
                    <input asp-for="LogDate" class="form-control" type="date"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="LogDate" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Content" class="form-label">
                        @Html.DisplayNameFor(m => m.Content)
                        <small class="text-muted">(min. 100 karakter)</small>
                    </label>
                    <textarea asp-for="Content" class="form-control" rows="8"
                              id="Content"></textarea>
                    <div class="char-counter">
                        <span id="charCount">0</span> / 100 karakter (minimum)
                    </div>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-actions mt-4">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save me-1"></i> Güncelle
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
    <script>
        const textarea = document.getElementById('Content');
        const counter = document.getElementById('charCount');
        function update() {
            counter.textContent = textarea.value.length;
            counter.style.color = textarea.value.length >= 100 ? '#198754' : '#dc3545';
        }
        textarea.addEventListener('input', update);
        update();
    </script>
}
