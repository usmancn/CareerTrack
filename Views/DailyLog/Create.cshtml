@model CareerTrack.Models.ViewModels.DailyLogCreateViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Yeni Günlük" : "Günlüğü Düzenle";
}

<div class="form-card">
    <div class="form-card-header">
        <i class="bi bi-journal-text me-2"></i>@ViewData["Title"]
    </div>
    <div class="form-card-body">
        <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            @if (Model.Id != 0) 
            { 
                <input type="hidden" asp-for="Id" /> 
            }

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="JobApplicationId" class="form-label"></label>
                    <select asp-for="JobApplicationId" class="form-select" asp-items="Model.Applications">
                        <option value="">-- Staj Seçiniz --</option>
                    </select>
                    <span asp-validation-for="JobApplicationId" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="DayNumber" class="form-label"></label>
                    <input asp-for="DayNumber" class="form-control" type="number" min="1" max="365" placeholder="14" />
                    <span asp-validation-for="DayNumber" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="LogDate" class="form-label"></label>
                    <input asp-for="LogDate" class="form-control" type="date" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="LogDate" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Content" class="form-label">
                        @Html.DisplayNameFor(m => m.Content)
                        <small class="text-muted">(min. 100 karakter)</small>
                    </label>
                    <textarea asp-for="Content" class="form-control" rows="8"
                              placeholder="Bugün neler yaptığınızı ayrıntılı yazınız. Kullandığınız teknolojiler, karşılaştığınız problemler ve çözümler..."></textarea>
                    <div class="char-counter">
                        <span id="charCount">0</span> / 100 karakter (minimum)
                    </div>
                    <span asp-validation-for="Content" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-actions mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
    <script>
        const textarea = document.getElementById('Content');
        const counter = document.getElementById('charCount');
        if (textarea && counter) {
            function update() {
                counter.textContent = textarea.value.length;
                counter.style.color = textarea.value.length >= 100 ? '#198754' : '#dc3545';
            }
            textarea.addEventListener('input', update);
            update();
        }
    </script>
}
