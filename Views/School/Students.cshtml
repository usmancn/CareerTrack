@model List<CareerTrack.Models.ViewModels.SchoolStudentDetailViewModel>
@using CareerTrack.Models.Enums
@{
    ViewData["Title"] = "Öğrenci Takibi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="bi bi-person-lines-fill me-2"></i>Öğrenci Takibi</h4>
    <span class="badge bg-secondary fs-6">@Model.Count öğrenci</span>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-person-x fs-1"></i>
            <p class="mt-3">Henüz kayıtlı öğrenci bulunmuyor.</p>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var student in Model)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="row align-items-center">
                        <!-- Sol: Öğrenci Bilgileri -->
                        <div class="col-md-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:48px;height:48px;font-size:1.2rem;font-weight:bold;color:var(--bs-primary);">
                                    @student.StudentName.Substring(0, 1).ToUpper()
                                </div>
                                <div>
                                    <div class="fw-bold">@student.StudentName</div>
                                    <small class="text-muted">@(student.Department ?? "Bölüm Belirtilmemiş")</small>
                                    <div class="small text-muted">@student.Email</div>
                                </div>
                            </div>
                        </div>

                        <!-- Orta: İstatistikler -->
                        <div class="col-md-5">
                            <div class="d-flex gap-3 flex-wrap">
                                <div class="text-center">
                                    <div class="fw-bold text-primary">@student.TotalApplications</div>
                                    <small class="text-muted">Başvuru</small>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold text-success">@student.OfferedCount</div>
                                    <small class="text-muted">Onaylı Staj</small>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold text-danger">@student.RejectedCount</div>
                                    <small class="text-muted">Reddedilen</small>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold text-info">@student.TotalDailyLogs</div>
                                    <small class="text-muted">Günlük</small>
                                </div>
                                <div class="text-center">
                                    <div class="fw-bold text-success">@student.ApprovedDailyLogs</div>
                                    <small class="text-muted">Onaylı</small>
                                </div>
                            </div>

                            <!-- Son Başvuru Durumu -->
                            @if (student.Applications.Any())
                            {
                                var lastApp = student.Applications.OrderByDescending(a => a.ApplicationDate).First();
                                <div class="mt-2">
                                    <small class="text-muted">Son başvuru: <strong>@lastApp.Company?.Name</strong> — </small>
                                    @{
                                        var (cls, lbl) = lastApp.Status switch
                                        {
                                            ApplicationStatus.SchoolApproved   => ("bg-success", "Staj Devam Ediyor"),
                                            ApplicationStatus.EmployerAccepted  => ("bg-warning text-dark", "Okul Onayı Bekleniyor"),
                                            ApplicationStatus.Pending           => ("bg-secondary", "İşveren İnceliyor"),
                                            ApplicationStatus.Rejected          => ("bg-danger", "Reddedildi"),
                                            ApplicationStatus.Completed         => ("bg-dark", "Tamamlandı"),
                                            _                                   => ("bg-info text-dark", "Süreç Devam Ediyor")
                                        };
                                    }
                                    <span class="badge @cls small">@lbl</span>
                                </div>
                            }
                        </div>

                        <!-- Sağ: Detay Butonu -->
                        <div class="col-md-3 text-end">
                            <a asp-action="StudentDetail" asp-route-id="@student.StudentId"
                               class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-eye me-1"></i>Detay Görüntüle
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
