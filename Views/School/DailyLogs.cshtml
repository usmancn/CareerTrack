@model List<CareerTrack.Models.Entities.DailyLog>
@{
    ViewData["Title"] = "Günlük Onayları";
}

<div class="table-card">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Öğrenci</th>
                <th>Gün</th>
                <th>Tarih</th>
                <th>İçerik</th>
                <th>Durum</th>
                <th class="text-end">İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td><strong>@log.Student?.FullName</strong></td>
                    <td>@log.DayNumber. Gün</td>
                    <td>@log.LogDate.ToString("dd.MM.yyyy")</td>
                    <td class="text-truncate" style="max-width:260px;">@log.Content</td>
                    <td>
                        @switch (log.Status)
                        {
                            case CareerTrack.Models.Enums.DailyLogStatus.EmployerApproved:
                                <span class="badge bg-warning text-dark">Okul Onayı Bekliyor</span>
                                break;
                            case CareerTrack.Models.Enums.DailyLogStatus.SchoolApproved:
                                <span class="badge bg-success">Onaylandı</span>
                                break;
                            case CareerTrack.Models.Enums.DailyLogStatus.SchoolRejected:
                                <span class="badge bg-danger">Revize İstendi</span>
                                break;
                            default:
                                <span class="badge bg-secondary">@log.Status</span>
                                break;
                        }
                    </td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary" 
                                onclick="openReviewDrawer(@log.Id, `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(log.Content))`, `@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(log.SchoolNote ?? ""))`)">
                            <i class="bi bi-eye me-1"></i>İncele
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Log İnceleme Yan Paneli -->
<div id="logReviewDrawer" class="premium-drawer">
    <div class="drawer-overlay" onclick="closePremiumDrawer('logReviewDrawer')"></div>
    <div class="drawer-content">
        <div class="drawer-header">
            <span class="drawer-title"><i class="bi bi-journal-text me-2 text-primary"></i>Günlük İnceleme</span>
            <button type="button" class="btn-drawer-close" onclick="closePremiumDrawer('logReviewDrawer')">
                <i class="bi bi-x"></i>
            </button>
        </div>
        <div class="drawer-body">
            <form asp-action="ApproveLog" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="modalLogId" />
                
                <div class="mb-4">
                    <label class="form-label text-muted small fw-bold">ÖĞRENCİNİN GİRDİĞİ İÇERİK</label>
                    <div class="p-3 rounded glass-panel" id="modalLogContent" style="min-height: 120px; white-space: pre-wrap; font-size: 0.95rem; line-height: 1.6; background: rgba(255,255,255,0.02); border: 1px solid var(--glass-border);"></div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Okul Notu (Opsiyonel / Revize için tavsiye edilir)</label>
                    <textarea name="schoolNote" id="modalNote" class="form-control glass-input" rows="4" placeholder="Öğrenciye iletmek istediğiniz notlar..."></textarea>
                </div>
                
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-outline-secondary flex-fill" onclick="closePremiumDrawer('logReviewDrawer')">Kapat</button>
                    <button type="submit" name="approve" value="false" class="btn btn-warning flex-fill"><i class="bi bi-arrow-repeat me-1"></i>Revize İste</button>
                    <button type="submit" name="approve" value="true" class="btn btn-success flex-fill text-dark fw-bold"><i class="bi bi-check-circle me-1"></i>Onayla</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openReviewDrawer(id, content, note) {
            document.getElementById('modalLogId').value = id;
            document.getElementById('modalLogContent').textContent = content;
            document.getElementById('modalNote').value = note || '';
            window.openPremiumDrawer('logReviewDrawer');
        }
    </script>
}
