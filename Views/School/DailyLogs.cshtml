@model List<CareerTrack.Models.Entities.DailyLog>
@{
    ViewData["Title"] = "Günlük Onayları";
}

<div class="table-card">
    <table class="table table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Öğrenci</th>
                <th>Gün</th>
                <th>Tarih</th>
                <th>İçerik</th>
                <th>Durum</th>
                <th class="text-end">İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td><strong>@log.Student?.FullName</strong></td>
                    <td>@log.DayNumber. Gün</td>
                    <td>@log.LogDate.ToString("dd.MM.yyyy")</td>
                    <td class="text-truncate" style="max-width:260px;">@log.Content</td>
                    <td>
                        @switch (log.Status)
                        {
                            case CareerTrack.Models.Enums.DailyLogStatus.EmployerApproved:
                                <span class="badge bg-warning text-dark">Okul Onayı Bekliyor</span>
                                break;
                            case CareerTrack.Models.Enums.DailyLogStatus.SchoolApproved:
                                <span class="badge bg-success">Onaylandı</span>
                                break;
                            case CareerTrack.Models.Enums.DailyLogStatus.SchoolRejected:
                                <span class="badge bg-danger">Revize İstendi</span>
                                break;
                            default:
                                <span class="badge bg-secondary">@log.Status</span>
                                break;
                        }
                    </td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                data-bs-target="#logModal" data-id="@log.Id"
                                data-content="@log.Content" data-note="@log.SchoolNote">
                            <i class="bi bi-eye me-1"></i>İncele
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="logModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-journal-text me-2"></i>Günlük İnceleme</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="modalContent" class="p-3 bg-light rounded"></p>
                <form asp-action="ApproveLog" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="modalLogId" />
                    <div class="mb-3">
                        <label class="form-label">Okul Notu</label>
                        <textarea name="schoolNote" id="modalNote" class="form-control" rows="2"
                                  placeholder="Öğrenciye notunuzu yazın..."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" name="approve" value="true" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i> Onayla
                        </button>
                        <button type="submit" name="approve" value="false" class="btn btn-warning">
                            <i class="bi bi-arrow-repeat me-1"></i> Revize İste
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('logModal').addEventListener('show.bs.modal', function (e) {
            const btn = e.relatedTarget;
            document.getElementById('modalLogId').value = btn.dataset.id;
            document.getElementById('modalContent').textContent = btn.dataset.content;
            document.getElementById('modalNote').value = btn.dataset.note || '';
        });
    </script>
}
