@model SchoolStudentDetailViewModel
@{
    ViewData["Title"] = Model.StudentName + " — Öğrenci Detay";
}

<a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3">
    <i class="bi bi-arrow-left me-1"></i> Okul Paneline Dön
</a>

<!-- Öğrenci Bilgi Kartı -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="user-avatar" style="width:56px;height:56px;font-size:1.5rem;display:flex;align-items:center;justify-content:center;background:var(--bs-primary);color:white;border-radius:50%;">
                    @Model.StudentName.Substring(0, 1).ToUpper()
                </div>
            </div>
            <div class="col">
                <h4 class="mb-1">@Model.StudentName</h4>
                <p class="text-muted mb-0">
                    <i class="bi bi-mortarboard me-1"></i>@(Model.Department ?? "Belirtilmemiş")
                    <span class="mx-2">|</span>
                    <i class="bi bi-envelope me-1"></i>@Model.Email
                </p>
            </div>
        </div>
    </div>
</div>

<!-- İstatistikler -->
<div class="row g-3 mb-4">
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-3">
                <h3 class="mb-0 text-primary">@Model.TotalApplications</h3>
                <small class="text-muted">Başvuru</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-3">
                <h3 class="mb-0 text-success">@Model.OfferedCount</h3>
                <small class="text-muted">Teklif</small>
            </div>
        </div>
    </div>
    <div class="col-md-2">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-3">
                <h3 class="mb-0 text-danger">@Model.RejectedCount</h3>
                <small class="text-muted">Red</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-3">
                <h3 class="mb-0 text-info">@Model.TotalDailyLogs</h3>
                <small class="text-muted">Günlük Kaydı</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-center">
            <div class="card-body py-3">
                <h3 class="mb-0 text-success">@Model.ApprovedDailyLogs</h3>
                <small class="text-muted">Onaylı Günlük</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Başvuruları -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-send me-2"></i>Başvuruları</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.Applications.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Şirket</th>
                                    <th>Pozisyon</th>
                                    <th>Tarih</th>
                                    <th>Durum</th>
                                    <th class="text-end">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var app in Model.Applications)
                                {
                                    <tr>
                                        <td>@app.Company?.Name</td>
                                        <td>@app.Position</td>
                                        <td>@app.ApplicationDate.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            @switch (app.Status)
                                            {
                                                case ApplicationStatus.SchoolApproved:
                                                    <span class="badge bg-success">Staj Devam Ediyor</span>
                                                    break;
                                                case ApplicationStatus.PreScreening:
                                                    <span class="badge bg-info text-dark">Ön Eleme</span>
                                                    break;
                                                case ApplicationStatus.AptitudeTest:
                                                    <span class="badge bg-primary">G.Y. Testi</span>
                                                    break;
                                                case ApplicationStatus.LanguageTest:
                                                    <span class="badge bg-primary">Dil Sınavı</span>
                                                    break;
                                                case ApplicationStatus.Interview:
                                                    <span class="badge bg-info">Mülakat</span>
                                                    break;
                                                case ApplicationStatus.EmployerAccepted:
                                                    <span class="badge bg-success">Kabul Edildi</span>
                                                    break;
                                                case ApplicationStatus.Rejected:
                                                    <span class="badge bg-danger">Reddedildi</span>
                                                    break;
                                                case ApplicationStatus.Completed:
                                                    <span class="badge bg-dark">Staj Bitti</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary">@app.Status.ToString()</span>
                                                    break;
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (app.Status == ApplicationStatus.SchoolApproved)
                                            {
                                                <form asp-action="CompleteInternship" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@app.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-success" onclick="return confirm('Öğrencinin tüm staj yükümlülüklerini (defter vb.) tamamladığını onaylıyor ve stajı resmi olarak bitiriyorsunuz. Emin misiniz?');">
                                                        <i class="bi bi-check-all me-1"></i>Stajı Tamamla
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-3">Henüz başvuru yok.</p>
                }
            </div>
        </div>
    </div>

    <!-- Staj Günlükleri -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-journal-text me-2"></i>Staj Günlükleri</h5>
            </div>
            <div class="card-body p-0">
                @if (Model.DailyLogs.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Gün</th>
                                    <th>Tarih</th>
                                    <th>Durum</th>
                                    <th>İçerik Özet</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model.DailyLogs)
                                {
                                    <tr>
                                        <td class="fw-semibold">@log.DayNumber. gün</td>
                                        <td>@log.LogDate.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            @switch (log.Status)
                                            {
                                                case CareerTrack.Models.Enums.DailyLogStatus.SchoolApproved:
                                                    <span class="badge bg-success">Okul Onaylı</span>
                                                    break;
                                                case CareerTrack.Models.Enums.DailyLogStatus.EmployerApproved:
                                                    <span class="badge bg-primary">İşveren Onaylı</span>
                                                    break;
                                                case CareerTrack.Models.Enums.DailyLogStatus.SentToEmployer:
                                                    <span class="badge bg-info text-dark">İşverende</span>
                                                    break;
                                                default:
                                                    <span class="badge bg-secondary">@log.Status.ToString()</span>
                                                    break;
                                            }
                                        </td>
                                        <td>@(log.Content.Length > 60 ? log.Content.Substring(0, 60) + "..." : log.Content)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted text-center py-3">Henüz günlük kaydı yok.</p>
                }
            </div>
        </div>
    </div>
</div>
