@model CareerTrack.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="auth-card">
    <div class="auth-card-header">
        <h2>Hesap Oluştur</h2>
        <p>Staj sürecini takip etmeye başla</p>
    </div>
    <div class="auth-card-body">
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            
            <div class="mb-4">
                <label class="form-label fw-semibold">Hesap Türü</label>
                <div class="d-flex gap-3">
                    <div class="flex-fill">
                        <input type="radio" class="btn-check" name="Role" id="roleStudent" value="Student" checked autocomplete="off" />
                        <label class="btn btn-outline-primary w-100" for="roleStudent">
                            <i class="bi bi-mortarboard-fill me-2"></i>Öğrenci
                        </label>
                    </div>
                    <div class="flex-fill">
                        <input type="radio" class="btn-check" name="Role" id="roleEmployer" value="Employer" autocomplete="off" />
                        <label class="btn btn-outline-success w-100" for="roleEmployer">
                            <i class="bi bi-building-fill me-2"></i>İşveren
                        </label>
                    </div>
                </div>
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-person"></i></span>
                    <input asp-for="FullName" class="form-control" placeholder="Ad Soyad" />
                </div>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" class="form-control" placeholder="ornek@email.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3" id="departmentField">
                <label asp-for="Department" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-mortarboard"></i></span>
                    <input asp-for="Department" class="form-control" placeholder="Bilgisayar Mühendisliği" />
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="En az 6 karakter" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Şifreyi tekrar girin" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div id="employerNote" class="alert alert-info d-none py-2 small">
                <i class="bi bi-info-circle me-1"></i>
                İşveren hesabınız oluşturulduktan sonra profilinizden şirket bilgilerinizi tamamlayabilirsiniz.
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-auth">Kayıt Ol</button>
        </form>

        <div class="auth-divider"><span>Zaten hesabın var mı?</span></div>
        <a asp-action="Login" class="btn btn-outline-primary w-100">Giriş Yap</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
    <script>
        const radios = document.querySelectorAll('input[name="Role"]');
        const employerNote = document.getElementById('employerNote');
        const deptField = document.getElementById('departmentField');

        radios.forEach(r => r.addEventListener('change', function () {
            if (this.value === 'Employer') {
                employerNote.classList.remove('d-none');
                deptField.querySelector('input').placeholder = 'İnsan Kaynakları / İK';
            } else {
                employerNote.classList.add('d-none');
                deptField.querySelector('input').placeholder = 'Bilgisayar Mühendisliği';
            }
        }));
    </script>
}

