@model CareerTrack.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_Layout";
}

<div class="auth-card">
    <div class="auth-card-header">
        <h2>Giriş Yap</h2>
        <p>Hesabınıza erişmek için bilgilerinizi girin</p>
    </div>
    <div class="auth-card-body">
        <form asp-action="Login" method="post" id="loginForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" id="emailInput" class="form-control" placeholder="ornek@email.com" autocomplete="username" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" id="passwordInput" class="form-control" placeholder="••••••" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 form-check">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Beni hatırla</label>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-auth">Giriş Yap</button>
        </form>

        
        <div class="mt-4">
            <p class="text-muted small text-center mb-2"><i class="bi bi-info-circle me-1"></i>Hızlı giriş için bir hesap seçin:</p>
            <div class="d-flex flex-column gap-2">
                <button class="btn btn-sm btn-outline-danger demo-login-btn"
                        data-email="admin@careertrack.com" data-pass="Admin123!">
                    <i class="bi bi-shield-fill-check me-2"></i>
                    <strong>Admin</strong> — admin@careertrack.com
                </button>
                <button class="btn btn-sm btn-outline-info demo-login-btn"
                        data-email="okul@careertrack.com" data-pass="Okul123!">
                    <i class="bi bi-bank me-2"></i>
                    <strong>Okul</strong> — okul@careertrack.com
                </button>
                <button class="btn btn-sm btn-outline-success demo-login-btn"
                        data-email="isveren@careertrack.com" data-pass="Isveren123!">
                    <i class="bi bi-building me-2"></i>
                    <strong>İşveren</strong> — isveren@careertrack.com
                </button>
                <button class="btn btn-sm btn-outline-secondary demo-login-btn"
                        data-email="ogrenci@careertrack.com" data-pass="Ogrenci123!">
                    <i class="bi bi-mortarboard me-2"></i>
                    <strong>Öğrenci</strong> — ogrenci@careertrack.com
                </button>
            </div>
        </div>

        <div class="auth-divider">
            <span>Hesabın yok mu?</span>
        </div>
        <a asp-action="Register" class="btn btn-outline-primary w-100">Kayıt Ol</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScripts" />
    <script>
        document.querySelectorAll('.demo-login-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.getElementById('emailInput').value = this.dataset.email;
                document.getElementById('passwordInput').value = this.dataset.pass;
                document.getElementById('loginForm').submit();
            });
        });
    </script>
}

